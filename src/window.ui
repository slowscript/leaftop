<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="LeaftopWindow" parent="GtkApplicationWindow">
    <property name="title">leaftop</property>
    <property name="default-width">800</property>
    <property name="default-height">600</property>
    <property name="titlebar">
      <object class="GtkHeaderBar" id="header_bar">
        <child type="title">
          <object class="GtkStackSwitcher">
            <property name="stack">stack</property>
          </object>
        </child>
        <child type="end">
          <object class="GtkMenuButton">
            <property name="primary">True</property>
            <property name="icon-name">open-menu-symbolic</property>
            <property name="tooltip-text" translatable="yes">Menu</property>
            <property name="menu-model">primary_menu</property>
          </object>
        </child>
      </object>
    </property>
    <property name="child">
      <object class="GtkStack" id="stack">
        <child>
          <object class="GtkStackPage">
            <property name="name">page_processes</property>
            <property name="title" translatable="yes">Processes</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkScrolledWindow" id="sw">
                    <property name="vexpand">true</property>
                    <property name="valign">fill</property>
                    <child>
                      <object class="GtkColumnView" id="column_view">
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="margin-top">4</property>
                    <property name="margin-start">4</property>
                    <property name="margin-bottom">4</property>
                    <property name="margin-end">4</property>
                    <property name="spacing">4</property>
                    <child>
                      <object class="GtkMenuButton" id="menuSignal">
                        <property name="icon-name">send_signal</property>
                        <property name="label" translatable="yes">Signal</property>
                        <property name="direction">GTK_ARROW_UP</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuButton">
                        <property name="icon-name">face-smile-symbolic</property>
                        <property name="label">Priority</property>
                        <property name="direction">GTK_ARROW_UP</property>
                        <property name="menu-model">priority_menu</property>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkLabel" id="lblCPUTotal">
                        <property name="width-request">80</property>
                        <property name="hexpand">true</property>
                        <property name="halign">end</property>
                        <property name="label">CPU: 0.0</property>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkLabel" id="lblMemTotal">
                        <property name="width-request">80</property>
                        <property name="halign">end</property>
                        <property name="label">Memory: 0.0</property>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkLabel" id="lblDiskTotal">
                        <property name="width-request">80</property>
                        <property name="halign">end</property>
                        <property name="label">Disk: 0.0</property>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkLabel" id="lblNetTotal">
                        <property name="width-request">120</property>
                        <property name="xalign">0</property>
                        <property name="label">Network: 0.0</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkStackPage">
            <property name="name">page_resources</property>
            <property name="title" translatable="yes">Resources</property>
            <property name="child">
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="hscrollbar-policy">never</property>
                    <child>
                      <object class="GtkBox" id="boxPageSwitcher">
                        <property name="orientation">vertical</property>
                        <property name="margin-start">4</property>
                        <property name="margin-end">4</property>
                        <property name="margin-top">4</property>
                        <property name="margin-bottom">4</property>
                        <property name="spacing">4</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkSeparator" />
                </child>
                <child>
                  <object class="GtkStack" id="stackResources">
                    <property name="hexpand">true</property>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>
      </object>
    </property>
  </template>
  <menu id="primary_menu">
    <section>
      <submenu>
        <attribute name="label" translatable="yes">Process _grouping</attribute>
        <section>
          <item>
            <attribute name="label" translatable="yes">Flat list</attribute>
            <attribute name="action">win.set-process-grouping</attribute>
            <attribute name="target">flat</attribute>
          </item>
          <item>
            <attribute name="label" translatable="yes">Simple grouping</attribute>
            <attribute name="action">win.set-process-grouping</attribute>
            <attribute name="target">simple</attribute>
          </item>
          <item>
            <attribute name="label" translatable="yes">Full tree</attribute>
            <attribute name="action">win.set-process-grouping</attribute>
            <attribute name="target">tree</attribute>
          </item>
          <item>
            <attribute name="label" translatable="yes">By cgroup</attribute>
            <attribute name="action">win.set-process-grouping</attribute>
            <attribute name="target">cgroup</attribute>
          </item>
        </section>
      </submenu>
      <item>
        <attribute name="label" translatable="yes">_Preferences</attribute>
        <attribute name="action">app.preferences</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
        <attribute name="action">win.show-help-overlay</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">_About leaftop</attribute>
        <attribute name="action">app.about</attribute>
      </item>
    </section>
  </menu>
  <menu id="priority_menu">
    <item>
      <attribute name="label" translatable="yes">-20 - Very high</attribute>
      <attribute name="action">win.set-nice</attribute>
      <attribute name="target" type="i">-20</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">-5 - High</attribute>
      <attribute name="action">win.set-nice</attribute>
      <attribute name="target" type="i">-5</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">0 - Normal</attribute>
      <attribute name="action">win.set-nice</attribute>
      <attribute name="target" type="i">0</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">5 - Low</attribute>
      <attribute name="action">win.set-nice</attribute>
      <attribute name="target" type="i">5</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">19 - Very low</attribute>
      <attribute name="action">win.set-nice</attribute>
      <attribute name="target" type="i">19</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">Custom</attribute>
      <attribute name="action">win.set-custom-nice</attribute>
    </item>
    <item>
      <attribute name="label" translatable="yes">Real-time</attribute>
      <attribute name="action">win.set-real-time</attribute>
    </item>
  </menu>
</interface>
